<%- include('./partials/header') %>
    <div class="w-full h-screen flex items-start px-20 py-20">
        <div class="w-[25%] flex h-screen flex-col items-start">
            <div class="flex flex-col">
                <a class="block w-fit mb-2" href="">All Products</a>
                <a class="block w-fit mb-2" href="/owners/createproducts">Create new product</a>
                <form action="/owners/logout" method="POST" class="mt-4">
                    <button type="submit" class="text-red-500 hover:text-red-700 font-medium">
                        <i class="ri-logout-box-line mr-1"></i>Logout
                    </button>
                </form>
            </div>
        </div>
        <div class="w-[75%] flex flex-col gap-5 h-screen">
            <div class="flex items-center justify-between mb-4">
                <a class="text-red-500" href="">Delete all</a>
                <% if (typeof unreadCount !== 'undefined' && unreadCount > 0) { %>
                    <div class="flex items-center gap-3 bg-blue-50 border border-blue-200 rounded-lg px-4 py-3">
                        <div class="relative">
                            <i class="ri-notification-3-line text-2xl text-blue-600"></i>
                            <% if (unreadCount > 0) { %>
                                <span class="absolute -top-1 -right-1 bg-red-500 text-white text-xs font-bold rounded-full w-5 h-5 flex items-center justify-center"><%= unreadCount %></span>
                            <% } %>
                        </div>
                        <div>
                            <p class="text-sm font-semibold text-gray-800">
                                <%= unreadCount %> New Order<%= unreadCount > 1 ? 's' : '' %>
                            </p>
                            <p class="text-xs text-gray-600">Check notifications below</p>
                        </div>
                    </div>
                <% } %>
            </div>
            
            <!-- Order Notifications Section -->
            <% if (typeof notifications !== 'undefined' && notifications.length > 0) { %>
                <div class="bg-white rounded-lg shadow-md p-4 mb-6 border-l-4 border-blue-500">
                    <h3 class="text-lg font-bold text-gray-800 mb-3 flex items-center gap-2">
                        <i class="ri-shopping-bag-3-line text-blue-600"></i>
                        Recent Orders
                    </h3>
                    <div class="space-y-2 max-h-48 overflow-y-auto">
                        <% notifications.slice(0, 5).forEach(function(notification) { %>
                            <div class="bg-blue-50 border border-blue-200 rounded-lg p-3 hover:bg-blue-100 transition-colors">
                                <div class="flex items-start justify-between">
                                    <div class="flex-1">
                                        <p class="text-sm font-semibold text-gray-800">
                                            <i class="ri-shopping-cart-line text-blue-600 mr-1"></i>
                                            Order #<%= notification.orderId %>
                                        </p>
                                        <p class="text-xs text-gray-600 mt-1">
                                            Customer: <span class="font-medium"><%= notification.customerName %></span>
                                        </p>
                                        <p class="text-xs text-gray-600">
                                            Email: <span class="font-medium"><%= notification.customerEmail %></span>
                                        </p>
                                        <p class="text-xs text-gray-600 mt-1">
                                            Total: <span class="font-bold text-green-600">₹<%= notification.orderTotal.toLocaleString('en-IN') %></span>
                                        </p>
                                        <p class="text-xs text-gray-500 mt-1">
                                            <%= new Date(notification.orderDate).toLocaleString('en-IN') %>
                                        </p>
                                    </div>
                                    <span class="bg-red-500 text-white text-xs px-2 py-1 rounded-full font-bold">New</span>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>
            <% } %>
            <div class="grid grid-cols-4 gap-5">
                <% if (products && products.length > 0) { %>
                    <% products.forEach(function(product){ %>
                        <div class="w-60 bg-white rounded-lg shadow-md overflow-hidden">
                            <div class="w-full h-52 bg-[<%= product.bgcolor %>] flex items-center justify-center">
                                <img class="h-[12rem] object-contain"
                                     src="data:image/jpeg;base64,<%= product.image.toString('base64') %>" 
                                     alt="<%= product.name %>">
                            </div>
                            <div class="px-4 py-4 bg-[<%= product.panelcolor %>] text-[<%= product.textcolor %>]">
                                <div class="flex justify-between items-center mb-2">
                                    <div>
                                        <h3 class="font-semibold"><%= product.name %></h3>
                                        <% if(product.discount && product.discount > 0) { %>
                                            <h4>
                                                <span class="line-through text-gray-400">₹ <%= product.price %></span>
                                                <span class="ml-2 text-green-600 font-bold">
                                                    ₹ <%= (product.price - (product.price * product.discount / 100)).toFixed(2) %>
                                                </span>
                                            </h4>
                                        <% } else { %>
                                            <h4 class="font-semibold">₹ <%= product.price %></h4>
                                        <% } %>
                                    </div>
                                </div>
                                <div class="flex items-center justify-between pt-2 border-t border-gray-300 border-opacity-30">
                                    <% const productStock = product.stock ?? 0; %>
                                    <div class="flex items-center gap-2">
                                        <i class="ri-stack-line text-sm"></i>
                                        <span class="text-sm font-medium">
                                            Stock: 
                                            <span class="<%= productStock > 0 ? 'text-green-600' : 'text-red-600' %> font-bold">
                                                <%= productStock %>
                                            </span>
                                        </span>
                                    </div>
                                    <form action="/products/update-stock/<%= product._id %>" method="POST" class="flex items-center gap-2">
                                        <input type="number" 
                                               name="stock" 
                                               value="<%= productStock %>" 
                                               min="0"
                                               class="w-20 px-2 py-1 text-xs border border-gray-300 rounded bg-white text-gray-800"
                                               required>
                                        <button type="submit" 
                                                class="px-2 py-1 text-xs bg-blue-500 hover:bg-blue-600 text-white rounded transition-colors">
                                            <i class="ri-save-line"></i> Update
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <p class="text-gray-500">No products found. Create your first product!</p>
                <% } %>
            </div>
        </div>
    </div>
    <%- include('./partials/footer') %>