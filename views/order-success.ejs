<%- include('./partials/header') %>

<style>
  @keyframes checkmark {
    0% {
      stroke-dashoffset: 100;
      opacity: 0;
    }
    50% {
      opacity: 1;
    }
    100% {
      stroke-dashoffset: 0;
      opacity: 1;
    }
  }
  
  @keyframes confetti {
    0% {
      transform: translateY(0) rotate(0deg);
      opacity: 1;
    }
    100% {
      transform: translateY(-100vh) rotate(720deg);
      opacity: 0;
    }
  }
  
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  @keyframes scaleIn {
    from {
      opacity: 0;
      transform: scale(0.8);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }
  
  .checkmark-circle {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    animation: checkmark 0.6s ease-out forwards;
  }
  
  .checkmark-check {
    stroke-dasharray: 50;
    stroke-dashoffset: 50;
    animation: checkmark 0.6s ease-out 0.3s forwards;
  }
  
  .confetti {
    position: fixed;
    width: 10px;
    height: 10px;
    background: #22c55e;
    animation: confetti 3s ease-out forwards;
  }
  
  .fade-in-up {
    animation: fadeInUp 0.6s ease-out forwards;
  }
  
  .scale-in {
    animation: scaleIn 0.5s ease-out forwards;
  }
</style>

<div class="min-h-screen bg-gradient-to-br from-green-50 via-blue-50 to-purple-50 py-8 px-4 sm:px-6 lg:px-8">
  <div class="max-w-4xl mx-auto">
    
   
    <div class="text-center mb-8 fade-in-up">
      <div class="inline-block relative scale-in">
        <!-- Success Circle with Checkmark -->
        <div class="w-32 h-32 mx-auto mb-6 bg-gradient-to-br from-green-400 to-green-600 rounded-full flex items-center justify-center shadow-2xl relative z-10">
          <svg class="w-20 h-20 text-white" viewBox="0 0 52 52">
            <circle class="checkmark-circle" cx="26" cy="26" r="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            <path class="checkmark-check" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" d="M14 27l8 8 16-16"/>
          </svg>
        </div>
        
        <!-- Confetti Effect -->
        <!-- <div id="confetti-container" class="fixed inset-0 pointer-events-none z-0"></div> -->
      </div>
      
      <h1 class="text-4xl md:text-5xl font-bold text-gray-800 mb-3">
        Order Placed Successfully!
      </h1>
      <p class="text-lg text-gray-600 mb-2">
        Thank you for your purchase. We're preparing your order.
      </p>
      <p class="text-sm text-gray-500">
        Order ID: <span class="font-semibold text-gray-700"><%= order.orderId %></span>
      </p>
    </div>

    <!-- Invoice Card -->
    <div class="bg-white rounded-2xl shadow-2xl overflow-hidden mb-6 fade-in-up" style="animation-delay: 0.2s; opacity: 0;">
      
      <!-- Invoice Header -->
      <div class="bg-gradient-to-r from-black to-gray-800 text-white px-6 py-4">
        <div class="flex justify-between items-center">
          <div>
            <h2 class="text-2xl font-bold flex items-center gap-2">
              <i class="ri-receipt-line"></i>
              Order Invoice
            </h2>
            <p class="text-gray-300 text-sm mt-1">Order Date: <%= new Date(order.orderDate).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' }) %></p>
          </div>
          <div class="text-right">
            <div class="text-sm text-gray-300">Order Status</div>
            <div class="text-lg font-semibold capitalize mt-1">
              <% if (order.status === 'pending') { %>
                <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-yellow-500/20 text-yellow-300">
                  <i class="ri-time-line"></i> Pending
                </span>
              <% } else if (order.status === 'paid') { %>
                <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-green-500/20 text-green-300">
                  <i class="ri-checkbox-circle-line"></i> Paid
                </span>
              <% } %>
            </div>
          </div>
        </div>
      </div>

      <div class="p-6">
        <!-- Shipping Address -->
        <div class="mb-6 pb-6 border-b border-gray-200">
          <h3 class="text-lg font-semibold text-gray-800 mb-3 flex items-center gap-2">
            <i class="ri-truck-line text-blue-600"></i>
            Delivery Address
          </h3>
          <div class="bg-gray-50 rounded-lg p-4">
            <p class="font-semibold text-gray-800"><%= order.shippingAddress.fullname %></p>
            <p class="text-gray-600 mt-1"><%= order.shippingAddress.address %></p>
            <p class="text-gray-600"><%= order.shippingAddress.city %>, <%= order.shippingAddress.state %> - <%= order.shippingAddress.pincode %></p>
            <p class="text-gray-600 mt-1">
              <i class="ri-phone-line"></i> <%= order.shippingAddress.contact %> | 
              <i class="ri-mail-line"></i> <%= order.shippingAddress.email %>
            </p>
          </div>
        </div>

        <!-- Order Items -->
        <div class="mb-6">
          <h3 class="text-lg font-semibold text-gray-800 mb-4 flex items-center gap-2">
            <i class="ri-shopping-bag-line text-blue-600"></i>
            Order Items
          </h3>
          <div class="space-y-3">
            <% order.items.forEach(function(item) { %>
              <div class="flex items-center gap-4 p-4 bg-gray-50 rounded-lg hover:bg-gray-100 transition">
                <div class="w-20 h-20 bg-white rounded-lg flex items-center justify-center overflow-hidden border border-gray-200">
                  <% if (item.product && item.product.image) { %>
                    <img src="data:image/jpeg;base64,<%= item.product.image.toString('base64') %>" 
                         alt="<%= item.productName %>"
                         class="w-full h-full object-contain">
                  <% } else { %>
                    <i class="ri-image-line text-3xl text-gray-300"></i>
                  <% } %>
                </div>
                <div class="flex-1">
                  <h4 class="font-semibold text-gray-800"><%= item.productName %></h4>
                  <p class="text-sm text-gray-600">Quantity: <%= item.quantity %></p>
                  <% if (item.discount > 0) { %>
                    <p class="text-sm text-gray-500">
                      <span class="line-through">₹<%= (item.price * item.quantity).toLocaleString('en-IN') %></span>
                      <span class="ml-2 text-green-600 font-semibold">₹<%= item.finalPrice.toLocaleString('en-IN') %></span>
                    </p>
                  <% } else { %>
                    <p class="text-sm text-gray-700 font-semibold">₹<%= item.finalPrice.toLocaleString('en-IN') %></p>
                  <% } %>
                </div>
              </div>
            <% }) %>
          </div>
        </div>

        <!-- Price Breakdown -->
        <div class="bg-gradient-to-r from-gray-50 to-blue-50 rounded-lg p-4 mb-4">
          <div class="space-y-2">
            <div class="flex justify-between text-gray-700">
              <span>Subtotal (<%= order.items.reduce((sum, item) => sum + item.quantity, 0) %> items)</span>
              <span class="font-semibold">₹<%= order.items.reduce((sum, item) => sum + item.finalPrice, 0).toLocaleString('en-IN') %></span>
            </div>
            <div class="flex justify-between text-gray-700">
              <span>Shipping</span>
              <span class="font-semibold text-green-600">FREE</span>
            </div>
            <% 
              const originalTotal = order.items.reduce((sum, item) => sum + (item.price * item.quantity), 0);
              const totalSavings = originalTotal - order.total;
            %>
            <% if (totalSavings > 0) { %>
            <div class="flex justify-between text-sm pt-2 border-t border-gray-200">
              <span class="text-red-600 font-medium">You Saved</span>
              <span class="text-red-600 font-bold">₹<%= Math.round(totalSavings).toLocaleString('en-IN') %></span>
            </div>
            <% } %>
          </div>
          <div class="flex justify-between items-center pt-4 mt-4 border-t-2 border-gray-300">
            <span class="text-xl font-bold text-gray-800">Total Amount</span>
            <span class="text-2xl font-bold text-gray-900">₹<%= order.total.toLocaleString('en-IN') %></span>
          </div>
        </div>

        <!-- Payment Method -->
        <div class="mb-4 pb-4 border-b border-gray-200">
          <h3 class="text-lg font-semibold text-gray-800 mb-2 flex items-center gap-2">
            <i class="ri-bank-card-line text-blue-600"></i>
            Payment Method
          </h3>
          <div class="flex items-center gap-2">
            <% if (order.paymentMethod === 'cod') { %>
              <i class="ri-money-rupee-circle-line text-2xl text-green-600"></i>
              <span class="text-gray-700">Cash on Delivery (COD)</span>
            <% } else if (order.paymentMethod === 'upi') { %>
              <i class="ri-qr-code-line text-2xl text-purple-600"></i>
              <span class="text-gray-700 font-semibold">UPI Payment</span>
              <span class="text-xs px-2 py-1 bg-purple-100 text-purple-700 rounded font-medium">PhonePe, GPay, Paytm</span>
            <% } else if (order.paymentMethod === 'card') { %>
              <i class="ri-bank-card-line text-2xl text-blue-600"></i>
              <span class="text-gray-700 font-semibold">Card Payment</span>
              <span class="text-xs px-2 py-1 bg-blue-100 text-blue-700 rounded font-medium">Visa, Mastercard, Rupay</span>
            <% } else { %>
              <i class="ri-bank-card-line text-2xl text-blue-600"></i>
              <span class="text-gray-700">Online Payment</span>
            <% } %>
          </div>
        </div>

        <!-- Estimated Delivery -->
        <div class="bg-gradient-to-r from-green-50 to-blue-50 rounded-lg p-4 border-2 border-green-200">
          <div class="flex items-start gap-3">
            <div class="bg-green-500 rounded-full p-2 mt-1">
              <i class="ri-calendar-check-line text-white text-xl"></i>
            </div>
            <div>
              <h3 class="font-semibold text-gray-800 mb-1">Estimated Delivery</h3>
              <p class="text-2xl font-bold text-green-600">
                <%= estimatedDeliveryDate.toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' }) %>
              </p>
              <p class="text-sm text-gray-600 mt-1">Your order will be delivered within 5-7 business days</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Action Buttons -->
    <div class="flex flex-col sm:flex-row gap-4 fade-in-up" style="animation-delay: 0.4s; opacity: 0;">
      <a href="/orders" 
         class="flex-1 bg-white border-2 border-gray-300 text-gray-700 text-center py-3 rounded-xl hover:bg-gray-50 transition-all text-base font-semibold shadow-md hover:shadow-lg">
        <i class="ri-file-list-line mr-2"></i>View All Orders
      </a>
      <a href="/shop" 
         class="flex-1 bg-gradient-to-r from-black to-gray-800 text-white text-center py-3 rounded-xl hover:from-gray-800 hover:to-black transition-all text-base font-semibold shadow-md hover:shadow-lg">
        <i class="ri-store-2-line mr-2"></i>Continue Shopping
      </a>
    </div>

  </div>
</div>

<script>
  // Confetti Animation
  function createConfetti() {
    const colors = ['#22c55e', '#3b82f6', '#8b5cf6', '#ec4899', '#f59e0b', '#ef4444'];
    const confettiContainer = document.getElementById('confetti-container');
    
    for (let i = 0; i < 50; i++) {
      setTimeout(() => {
        const confetti = document.createElement('div');
        confetti.className = 'confetti';
        confetti.style.left = Math.random() * 100 + '%';
        confetti.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];
        confetti.style.animationDelay = Math.random() * 2 + 's';
        confetti.style.width = (Math.random() * 8 + 6) + 'px';
        confetti.style.height = confetti.style.width;
        confetti.style.borderRadius = Math.random() > 0.5 ? '50%' : '0';
        confettiContainer.appendChild(confetti);
        
        setTimeout(() => confetti.remove(), 3000);
      }, i * 50);
    }
  }

  // Trigger animations on page load
  window.addEventListener('load', () => {
    createConfetti();
    
    // Animate fade-in-up elements
    document.querySelectorAll('.fade-in-up').forEach((el, index) => {
      setTimeout(() => {
        el.style.opacity = '1';
      }, index * 100);
    });
  });

  // Print invoice functionality
  function printInvoice() {
    window.print();
  }
</script>

<%- include('./partials/footer') %>

