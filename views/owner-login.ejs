<%- include('./partials/header') %>
    <div class="w-full h-screen flex px-20">
        <div class="w-1/2 flex items-center justify-center h-screen">
            <div class="w-full px-32">
                <h4 class="text-2xl capitalize mb-5">Admin Access</h4>
                
                <% if(error.length>0){ %>
                    <div class="mb-4 p-3 rounded-md bg-red-100 border border-red-400 text-red-700">
                        <%= error %>
                    </div>
                <% } %>
                
                <% if(success.length>0){ %>
                    <div class="mb-4 p-3 rounded-md bg-green-100 border border-green-400 text-green-700">
                        <%= success %>
                    </div>
                <% } %>
                
                <form action="/owners/login" method="post">
                    <input class="block bg-zinc-100 w-full px-3 py-2 border-[1px] rounded-md mb-3 border-zinc-200"
                        type="email" placeholder="Email" name="email" required>
                    <input class="block bg-zinc-100 w-full px-3 py-2 border-[1px] rounded-md mb-3 border-zinc-200"
                        type="password" placeholder="Password" name="password" required>
                    <input class="px-5 rounded-full py-3 mt-2 bg-blue-500 text-white hover:bg-blue-600 cursor-pointer transition-colors w-full" type="submit" value="Login">
                </form>
                
                <div class="mt-4 text-center">
                    <p class="text-sm text-gray-600">Don't have an owner account?</p>
                    <a href="/owners/setup" class="text-sm text-blue-600 hover:text-blue-800 underline">Setup Owner Account</a>
                    <p class="text-xs text-gray-500 mt-2">Note: Only one owner account is allowed</p>
                </div>
            </div>
        </div>
    </div>
    <%- include('./partials/footer') %>