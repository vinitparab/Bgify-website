<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bagify | E-Commerce</title>
  <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet" />
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="font-['helvetica_now_display'] bg-gray-50">

  <!-- Navbar -->
  <nav class="w-full sticky top-0 bg-white shadow-md z-50">
    <div class="max-w-7xl mx-auto flex justify-between items-center px-6 py-4">

      <!-- Brand Logo -->
      <div class="flex items-center gap-3">
        <h3 class="text-3xl font-extrabold tracking-widest text-transparent bg-clip-text bg-gradient-to-r from-green-400 to-blue-500 hover:scale-105 transition-transform cursor-pointer">
          Bagify
        </h3>
        <i class="ri-bag-line text-green-500 text-2xl"></i>
      </div>

      

      <!-- Links & Account -->
      <% var loggedin = typeof loggedin !== "undefined" ? loggedin : true %>
      <% if (loggedin) { %>
        <div class="flex items-center gap-6">

          <!-- Shop Link -->
          <a href="/shop" class="flex items-center gap-1 text-gray-700 hover:text-green-600 transition">
            <i class="ri-store-2-line"></i> Shop
          </a>

          <!-- Cart Icon -->
          <a href="/cart" class="flex items-center gap-1 text-gray-700 hover:text-green-600 transition">
            <i class="ri-shopping-cart-line text-2xl"></i> Cart
          </a>

          <!-- Account Dropdown -->
          <div class="relative group">
            <button
              class="flex items-center gap-1 text-gray-700 hover:text-green-600 transition font-medium">
              <i class="ri-user-3-line"></i> My Account <i class="ri-arrow-down-s-line"></i>
            </button>
            <div
              class="absolute right-0 mt-2 w-40 bg-white shadow-lg rounded-md opacity-0 group-hover:opacity-100 invisible group-hover:visible transition-all duration-200">
              <a href="/profile" class="block px-4 py-2 hover:bg-gray-100">Profile</a>
              <a href="/orders" class="block px-4 py-2 hover:bg-gray-100">Orders</a>
              <a href="/users/logout" class="block px-4 py-2 text-red-600 hover:bg-gray-100">Logout</a>
            </div>
          </div>

        </div>
      <% } %>

    </div>
  </nav>

</body>

</html>
