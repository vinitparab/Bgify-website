<%- include('./partials/header') %>

<!-- Flash Messages -->
<% if (success && success.length > 0) { %>
  <div id="flashMessage"
       style="position: fixed; top: 1.5rem; left: 50%; transform: translateX(-50%) translateY(-100px); padding: 0.875rem 1.25rem; border-radius: 0.75rem; background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%); color: white; box-shadow: 0 20px 25px -5px rgba(34, 197, 94, 0.3), 0 10px 10px -5px rgba(34, 197, 94, 0.2); z-index: 9999; transition: all 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55); font-weight: 600; font-size: 0.9375rem; display: flex; align-items: center; gap: 0.625rem; min-width: 280px; justify-content: center; backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.2);">
    <i class="ri-checkbox-circle-fill" style="font-size: 1.25rem;"></i>
    <span><%= success[0] %></span>
  </div>
<% } %>

<script>
  (function() {
    const successFlash = document.getElementById('flashMessage');
    if (successFlash) {
      setTimeout(() => {
        successFlash.style.transform = 'translateX(-50%) translateY(0)';
      }, 10);
      setTimeout(() => {
        successFlash.style.opacity = '0';
        successFlash.style.transform = 'translateX(-50%) translateY(-100px)';
        setTimeout(() => successFlash.remove(), 400);
      }, 2000);
    }
  })();
</script>

<div class="w-full min-h-screen bg-gray-50 py-10 px-4 sm:px-6 lg:px-20">
  <div class="max-w-6xl mx-auto">
    <div class="flex items-center justify-between mb-8">
      <h1 class="text-3xl font-bold text-gray-800 flex items-center gap-2">
        <i class="ri-shopping-bag-3-line text-blue-600"></i>
        My Orders
      </h1>
      <a href="/shop" class="text-blue-600 hover:text-blue-700 font-semibold flex items-center gap-2">
        <i class="ri-store-line"></i>Continue Shopping
      </a>
    </div>
    
    <% if (orders && orders.length > 0) { %>
      <div class="space-y-6">
        <% orders.reverse().forEach(function(order) { %>
          <div class="bg-white rounded-xl shadow-md p-6 border border-gray-100 hover:shadow-lg transition-shadow">
            <!-- Order Header -->
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6 pb-4 border-b border-gray-200">
              <div>
                <div class="flex items-center gap-3 mb-2">
                  <h3 class="text-lg font-bold text-gray-800">Order #<%= order.orderId %></h3>
                  <span class="px-3 py-1 rounded-full text-xs font-semibold 
                    <%= order.status === 'paid' ? 'bg-green-100 text-green-700' : 
                        order.status === 'pending' ? 'bg-yellow-100 text-yellow-700' : 
                        'bg-gray-100 text-gray-700' %>">
                    <%= order.status === 'paid' ? 'Paid' : 
                        order.status === 'pending' ? 'Pending' : 
                        order.status %>
                  </span>
                </div>
                <p class="text-sm text-gray-500">
                  <i class="ri-calendar-line mr-1"></i>
                  <%= new Date(order.orderDate).toLocaleDateString('en-IN', { 
                    year: 'numeric', 
                    month: 'long', 
                    day: 'numeric',
                    hour: '2-digit',
                    minute: '2-digit'
                  }) %>
                </p>
              </div>
              <div class="text-right mt-2 sm:mt-0">
                <div class="text-2xl font-bold text-gray-900">₹<%= order.total.toLocaleString('en-IN') %></div>
                <div class="text-sm text-gray-500"><%= order.items.length %> <%= order.items.length === 1 ? 'item' : 'items' %></div>
              </div>
            </div>
            
            <!-- Order Items -->
            <div class="space-y-4 mb-6">
              <% order.items.forEach(function(orderItem) { %>
                <div class="flex items-center gap-4 p-4 bg-gray-50 rounded-lg">
                  <div class="w-20 h-20 bg-white rounded-lg flex items-center justify-center overflow-hidden border border-gray-200">
                    <% if (orderItem.product && orderItem.product.image) { %>
                      <img src="data:image/jpeg;base64,<%= orderItem.product.image.toString('base64') %>" 
                           alt="<%= orderItem.productName %>"
                           class="w-full h-full object-contain">
                    <% } else { %>
                      <i class="ri-shopping-bag-line text-3xl text-gray-300"></i>
                    <% } %>
                  </div>
                  <div class="flex-1">
                    <h4 class="font-semibold text-gray-800"><%= orderItem.productName %></h4>
                    <div class="flex items-center gap-4 mt-1 text-sm text-gray-600">
                      <span>Qty: <%= orderItem.quantity %></span>
                      <% if (orderItem.discount > 0) { %>
                        <span class="line-through text-gray-400">₹<%= (orderItem.price * orderItem.quantity).toLocaleString('en-IN') %></span>
                        <span class="text-green-600 font-semibold">
                          ₹<%= orderItem.finalPrice.toLocaleString('en-IN') %>
                        </span>
                      <% } else { %>
                        <span>₹<%= orderItem.finalPrice.toLocaleString('en-IN') %></span>
                      <% } %>
                    </div>
                  </div>
                  <div class="text-right">
                    <div class="text-lg font-bold text-gray-900">₹<%= orderItem.finalPrice.toLocaleString('en-IN') %></div>
                  </div>
                </div>
              <% }) %>
            </div>
            
            <!-- Shipping Address -->
            <% if (order.shippingAddress) { %>
            <div class="pt-4 border-t border-gray-200">
              <h4 class="font-semibold text-gray-700 mb-2 flex items-center gap-2">
                <i class="ri-map-pin-line text-blue-600"></i>
                Shipping Address
              </h4>
              <div class="text-sm text-gray-600 bg-gray-50 p-4 rounded-lg">
                <p class="font-semibold text-gray-800"><%= order.shippingAddress.fullname %></p>
                <p><%= order.shippingAddress.address %></p>
                <p><%= order.shippingAddress.city %>, <%= order.shippingAddress.state %> - <%= order.shippingAddress.pincode %></p>
                <p class="mt-2">
                  <i class="ri-phone-line mr-1"></i><%= order.shippingAddress.contact %>
                  <span class="mx-2">•</span>
                  <i class="ri-mail-line mr-1"></i><%= order.shippingAddress.email %>
                </p>
              </div>
            </div>
            <% } %>
            
            <!-- Payment Info -->
            <div class="pt-4 border-t border-gray-200 mt-4">
              <div class="flex items-center justify-between text-sm">
                <span class="text-gray-600 flex items-center gap-2">
                  <% if (order.paymentMethod === 'cod') { %>
                    <i class="ri-money-rupee-circle-line text-green-600"></i>
                    <span>Payment: <span class="font-semibold text-gray-800">Cash on Delivery</span></span>
                  <% } else if (order.paymentMethod === 'upi') { %>
                    <i class="ri-qr-code-line text-purple-600"></i>
                    <span>Payment: <span class="font-semibold text-gray-800">UPI Payment</span></span>
                  <% } else if (order.paymentMethod === 'card') { %>
                    <i class="ri-bank-card-line text-blue-600"></i>
                    <span>Payment: <span class="font-semibold text-gray-800">Card Payment</span></span>
                  <% } else { %>
                    <i class="ri-bank-card-line"></i>
                    <span>Payment: <span class="font-semibold text-gray-800">Online Payment</span></span>
                  <% } %>
                </span>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <!-- Empty State -->
      <div class="bg-white rounded-xl shadow-md p-16 text-center">
        <i class="ri-shopping-bag-3-line text-6xl text-gray-300 mb-4"></i>
        <h3 class="text-2xl font-bold text-gray-700 mb-2">No Orders Yet</h3>
        <p class="text-gray-500 mb-6">You haven't placed any orders yet. Start shopping to see your orders here!</p>
        <a href="/shop" class="inline-block bg-blue-600 hover:bg-blue-700 text-white px-8 py-3 rounded-lg font-semibold transition-all shadow-md hover:shadow-lg">
          <i class="ri-store-line mr-2"></i>Start Shopping
        </a>
      </div>
    <% } %>
  </div>
</div>

<%- include('./partials/footer') %>



