<%- include('./partials/header') %>

<!-- Flash Messages -->
<% if (success && success.length > 0) { %>
  <div id="flashMessage"
       style="position: fixed; top: 8rem; left: 50%; transform: translateX(-50%); padding: 1rem 1.5rem; border-radius: 0.5rem; background-color: #22c55e; color: white; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1), 0 4px 6px -2px rgba(0,0,0,0.05); z-index: 9999; transition: all 0.5s ease; border: 2px solid #16a34a; font-weight: 500;">
    <%= success[0] %>
  </div>
  <script>
    setTimeout(() => {
      const flash = document.getElementById('flashMessage');
      if (flash) {
        flash.style.opacity = '0';
        flash.style.transform = 'translateX(-50%) translateY(-20px)';
        setTimeout(() => flash.remove(), 500);
      }
    }, 4000);
  </script>
<% } %>

<% if (error && error.length > 0) { %>
  <div id="flashMessageError"
       style="position: fixed; top: 8rem; left: 50%; transform: translateX(-50%); padding: 1rem 1.5rem; border-radius: 0.5rem; background-color: #ef4444; color: white; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1), 0 4px 6px -2px rgba(0,0,0,0.05); z-index: 9999; transition: all 0.5s ease; border: 2px solid #dc2626; font-weight: 500;">
    <%= error[0] %>
  </div>
  <script>
    setTimeout(() => {
      const flash = document.getElementById('flashMessageError');
      if (flash) {
        flash.style.opacity = '0';
        flash.style.transform = 'translateX(-50%) translateY(-20px)';
        setTimeout(() => flash.remove(), 500);
      }
    }, 4000);
  </script>
<% } %>

<div class="w-full min-h-screen flex px-20 py-20 gap-10 bg-gray-50">
  <!-- Sidebar -->
  <div class="w-[22%] flex flex-col sticky top-20 h-fit p-5 bg-white rounded-lg shadow-md">
    <h3 class="text-lg font-semibold mb-3">Sort by</h3>
    <form action="/shop">
      <select class="w-full border px-3 py-2 rounded-md focus:ring-2 focus:ring-blue-500">
        <option value="popular">Popular</option>
        <option value="newest">Newest</option>
      </select>
    </form>

    <div class="mt-10">
      <h4 class="font-semibold text-gray-700 mb-2">Collections</h4>
      <a class="block text-gray-600 hover:text-blue-600 mb-2" href="">New Collection</a>
      <a class="block text-gray-600 hover:text-blue-600 mb-2" href="">All Products</a>
      <a class="block text-gray-600 hover:text-blue-600 mb-2" href="">Discounted Products</a>
    </div>

    <div class="mt-10">
      <h4 class="font-semibold text-gray-700 mb-2">Filter By</h4>
      <a class="block text-gray-600 hover:text-blue-600 mb-2" href="">Availability</a>
      <a class="block text-gray-600 hover:text-blue-600 mb-2" href="">Discount</a>
    </div>
  </div>

  <!-- Product Grid -->
  <div class="w-[78%] flex flex-col gap-5">
    <h2 class="text-2xl font-bold mb-5">Our Products</h2>

    <div class="grid grid-cols-3 gap-8">
      <% products.forEach(function(product){ %>
        <div class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-xl transition duration-300 group">
          <!-- Product Image -->
          <div class="relative w-full h-56 bg-[<%= product.bgcolor %>] flex items-center justify-center">
            <img class="h-[12rem] object-contain transition-transform duration-300 group-hover:scale-110"
                 src="data:image/jpeg;base64,<%= product.image.toString('base64') %>" 
                 alt="<%= product.name %>">

            <% if(product.discount && product.discount > 0) { %>
              <span class="absolute top-3 left-3 bg-red-500 text-white text-xs px-2 py-1 rounded-md shadow">
                <%= product.discount %>% OFF
              </span>
            <% } %>
          </div>

          <!-- Product Info -->
          <div class="px-5 py-4 flex flex-col gap-2 bg-[<%= product.panelcolor %>] text-[<%= product.textcolor %>]">
            <h3 class="text-lg font-semibold"><%= product.name %></h3>

            <% if(product.discount && product.discount > 0) { %>
              <h4>
                <span class="line-through text-gray-400">₹ <%= product.price %></span>
                <span class="ml-2 text-green-600 font-bold">
                  ₹ <%= (product.price - (product.price * product.discount / 100)).toFixed(2) %>
                </span>
              </h4>
            <% } else { %>
              <h4 class="font-semibold">₹ <%= product.price %></h4>
            <% } %>

            <!-- Add to Cart Button -->
            <a href="/addtocart/<%= product._id %>" 
               class="mt-3 inline-flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 text-white py-2 px-4 rounded-md text-sm font-medium shadow-md transition-all">
              <i class="ri-shopping-cart-line"></i> Add to Cart
            </a>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</div>

<%- include('./partials/footer') %>