<%- include('./partials/header') %>

<!-- Flash Messages -->
<% if (success && success.length > 0) { %>
  <div id="flashMessage"
       style="position: fixed; top: 1.5rem; left: 50%; transform: translateX(-50%) translateY(-100px); padding: 0.875rem 1.25rem; border-radius: 0.75rem; background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%); color: white; box-shadow: 0 20px 25px -5px rgba(34, 197, 94, 0.3), 0 10px 10px -5px rgba(34, 197, 94, 0.2); z-index: 9999; transition: all 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55); font-weight: 600; font-size: 0.9375rem; display: flex; align-items: center; gap: 0.625rem; min-width: 280px; justify-content: center; backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.2);">
    <i class="ri-checkbox-circle-fill" style="font-size: 1.25rem;"></i>
    <span><%= success[0] %></span>
  </div>
<% } %>

<% if (error && error.length > 0) { %>
  <div id="flashMessageError"
       style="position: fixed; top: 1.5rem; left: 50%; transform: translateX(-50%) translateY(-100px); padding: 0.875rem 1.25rem; border-radius: 0.75rem; background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%); color: white; box-shadow: 0 20px 25px -5px rgba(239, 68, 68, 0.3), 0 10px 10px -5px rgba(239, 68, 68, 0.2); z-index: 9999; transition: all 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55); font-weight: 600; font-size: 0.9375rem; display: flex; align-items: center; gap: 0.625rem; min-width: 280px; justify-content: center; backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.2);">
    <i class="ri-error-warning-fill" style="font-size: 1.25rem;"></i>
    <span><%= error[0] %></span>
  </div>
<% } %>

<script>
  // Flash message animation handler
  (function() {
    const successFlash = document.getElementById('flashMessage');
    const errorFlash = document.getElementById('flashMessageError');
    
    function animateFlash(flash) {
      if (!flash) return;
      
      // Slide in animation
      setTimeout(() => {
        flash.style.transform = 'translateX(-50%) translateY(0)';
      }, 10);
      
      // Auto dismiss after 2 seconds
      setTimeout(() => {
        flash.style.opacity = '0';
        flash.style.transform = 'translateX(-50%) translateY(-100px)';
        flash.style.scale = '0.9';
        setTimeout(() => flash.remove(), 400);
      }, 2000);
    }
    
    animateFlash(successFlash);
    animateFlash(errorFlash);
  })();
</script>

<div class="w-full min-h-screen flex px-20 py-20 gap-10 bg-gray-50">
  <!-- Sidebar -->
  <div class="w-[22%] flex flex-col sticky top-20 h-fit p-6 bg-white rounded-xl shadow-lg border border-gray-100">
    <!-- Collections Section -->
    <div class="mb-8">
      <h4 class="font-bold text-lg text-gray-800 mb-4 flex items-center gap-2">
        <i class="ri-folder-line text-blue-600"></i>
        Collections
      </h4>
      <div class="space-y-2">
        <a class="block px-4 py-2.5 rounded-lg text-gray-700 hover:bg-blue-50 hover:text-blue-600 transition-all <%= typeof showNewCollection !== 'undefined' && showNewCollection ? 'bg-blue-50 text-blue-600 font-semibold border-l-4 border-blue-600' : '' %>" 
           href="/shop?new=true">
          <i class="ri-sparkling-line mr-2"></i>New Collection
        </a>
        <a class="block px-4 py-2.5 rounded-lg text-gray-700 hover:bg-blue-50 hover:text-blue-600 transition-all <%= (typeof showDiscountedOnly === 'undefined' || !showDiscountedOnly) && (typeof showNewCollection === 'undefined' || !showNewCollection) ? 'bg-blue-50 text-blue-600 font-semibold border-l-4 border-blue-600' : '' %>" 
           href="/shop">
          <i class="ri-store-line mr-2"></i>All Products
        </a>
        <a class="block px-4 py-2.5 rounded-lg text-gray-700 hover:bg-blue-50 hover:text-blue-600 transition-all <%= typeof showDiscountedOnly !== 'undefined' && showDiscountedOnly ? 'bg-blue-50 text-blue-600 font-semibold border-l-4 border-blue-600' : '' %>" 
           href="/shop?discount=true">
          <i class="ri-price-tag-3-line mr-2"></i>Discounted Products
        </a>
      </div>
    </div>

    <!-- Price Filter Section -->
    <div class="border-t border-gray-200 pt-6">
      <h4 class="font-bold text-lg text-gray-800 mb-4 flex items-center gap-2">
        <i class="ri-price-tag-line text-blue-600"></i>
        Filter By Price
      </h4>
      <form id="priceFilterForm" action="/shop" method="GET" class="space-y-4">
        <!-- Price Range Display -->
        <div class="flex justify-between items-center mb-3 px-2">
          <div class="text-center">
            <span class="text-xs text-gray-500 block mb-1">Min</span>
            <span class="text-base font-bold text-gray-800">₹ <span id="minPriceDisplay"><%= typeof minPrice !== 'undefined' ? Math.round(minPrice) : Math.round(priceMin) %></span></span>
          </div>
          <div class="text-gray-400">-</div>
          <div class="text-center">
            <span class="text-xs text-gray-500 block mb-1">Max</span>
            <span class="text-base font-bold text-gray-800">₹ <span id="maxPriceDisplay"><%= typeof maxPrice !== 'undefined' ? Math.round(maxPrice) : Math.round(priceMax) %></span></span>
          </div>
        </div>
        
        <!-- Dual Range Slider Container -->
        <div class="relative py-6">
          <!-- Track -->
          <div class="h-2 bg-gray-200 rounded-full relative">
            <!-- Active Range -->
            <div id="activeRange" class="absolute h-2 bg-blue-600 rounded-full" style="left: 0%; width: 100%;"></div>
          </div>
          
          <!-- Min Price Slider -->
          <input type="range" 
                 name="minPrice" 
                 id="minPriceSlider"
                 min="<%= priceMin %>"
                 max="<%= priceMax %>"
                 value="<%= typeof minPrice !== 'undefined' ? minPrice : priceMin %>"
                 step="100"
                 class="absolute top-6 w-full h-2 bg-transparent appearance-none cursor-pointer z-10">
          
          <!-- Max Price Slider -->
          <input type="range" 
                 name="maxPrice" 
                 id="maxPriceSlider"
                 min="<%= priceMin %>"
                 max="<%= priceMax %>"
                 value="<%= typeof maxPrice !== 'undefined' ? maxPrice : priceMax %>"
                 step="100"
                 class="absolute top-6 w-full h-2 bg-transparent appearance-none cursor-pointer z-20">
        </div>
        
        <!-- Hidden inputs for form submission -->
        <input type="hidden" name="minPrice" id="minPrice" value="<%= typeof minPrice !== 'undefined' ? minPrice : priceMin %>">
        <input type="hidden" name="maxPrice" id="maxPrice" value="<%= typeof maxPrice !== 'undefined' ? maxPrice : priceMax %>">
        <% if (typeof showDiscountedOnly !== 'undefined' && showDiscountedOnly) { %>
          <input type="hidden" name="discount" value="true">
        <% } %>
        <% if (typeof showNewCollection !== 'undefined' && showNewCollection) { %>
          <input type="hidden" name="new" value="true">
        <% } %>
        
        <div class="flex gap-2 mt-6">
          <button type="submit" 
                  class="flex-1 bg-blue-600 hover:bg-blue-700 text-white py-2.5 px-4 rounded-lg text-sm font-semibold transition-all shadow-md hover:shadow-lg">
            <i class="ri-check-line mr-1"></i>Apply
          </button>
          <a href="/shop" 
             class="flex-1 bg-gray-100 hover:bg-gray-200 text-gray-700 py-2.5 px-4 rounded-lg text-sm font-semibold text-center transition-all">
            <i class="ri-close-line mr-1"></i>Clear
          </a>
        </div>
      </form>
    </div>
  </div>

  <!-- Product Grid -->
  <div class="w-[78%] flex flex-col gap-5">
    <h2 class="text-2xl font-bold mb-5">Our Products</h2>

    <div class="grid grid-cols-3 gap-8">
      <% products.forEach(function(product){ %>
        <div class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-xl transition duration-300 group">
          <!-- Product Image -->
          <div class="relative w-full h-56 bg-[<%= product.bgcolor %>] flex items-center justify-center">
            <img class="h-[12rem] object-contain transition-transform duration-300 group-hover:scale-110"
                 src="data:image/jpeg;base64,<%= product.image.toString('base64') %>" 
                 alt="<%= product.name %>">

            <% if(product.discount && product.discount > 0) { %>
              <span class="absolute top-3 left-3 bg-red-500 text-white text-xs px-2 py-1 rounded-md shadow">
                <%= product.discount %>% OFF
              </span>
            <% } %>
          </div>

          <!-- Product Info -->
          <div class="px-5 py-4 flex flex-col gap-2 bg-[<%= product.panelcolor %>] text-[<%= product.textcolor %>]">
            <h3 class="text-lg font-semibold"><%= product.name %></h3>

            <% if(product.discount && product.discount > 0) { %>
              <h4>
                <span class="line-through text-gray-400">₹ <%= product.price %></span>
                <span class="ml-2 text-green-600 font-bold">
                  ₹ <%= (product.price - (product.price * product.discount / 100)).toFixed(2) %>
                </span>
              </h4>
            <% } else { %>
              <h4 class="font-semibold">₹ <%= product.price %></h4>
            <% } %>

            <!-- Add to Cart Button -->
            <% const productStock = product.stock ?? 0; %>
            <% if (productStock > 0) { %>
              <button data-product-id="<%= product._id %>" 
                 class="add-to-cart-btn mt-3 inline-flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 text-white py-2 px-4 rounded-md text-sm font-medium shadow-md transition-all disabled:opacity-50 disabled:cursor-not-allowed">
                <i class="ri-shopping-cart-line"></i> <span class="btn-text">Add to Cart</span>
              </button>
            <% } else { %>
              <button disabled
                 class="mt-3 inline-flex items-center justify-center gap-2 bg-gray-400 text-white py-2 px-4 rounded-md text-sm font-medium shadow-md cursor-not-allowed">
                <i class="ri-close-circle-line"></i> <span>Out of Stock</span>
              </button>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</div>

<script>
  // Function to show flash message
  function showFlashMessage(message, type = 'success') {
    const flashId = type === 'success' ? 'flashMessage' : 'flashMessageError';
    const existingFlash = document.getElementById(flashId);
    if (existingFlash) {
      existingFlash.remove();
    }

    const icon = type === 'success' 
      ? '<i class="ri-checkbox-circle-fill" style="font-size: 1.25rem;"></i>'
      : '<i class="ri-error-warning-fill" style="font-size: 1.25rem;"></i>';
    
    const bgGradient = type === 'success'
      ? 'linear-gradient(135deg, #22c55e 0%, #16a34a 100%)'
      : 'linear-gradient(135deg, #ef4444 0%, #dc2626 100%)';
    
    const shadowColor = type === 'success'
      ? 'rgba(34, 197, 94, 0.3)'
      : 'rgba(239, 68, 68, 0.3)';

    const flashDiv = document.createElement('div');
    flashDiv.id = flashId;
    flashDiv.innerHTML = `${icon}<span>${message}</span>`;
    flashDiv.style.cssText = `position: fixed; top: 1.5rem; left: 50%; transform: translateX(-50%) translateY(-100px); padding: 0.875rem 1.25rem; border-radius: 0.75rem; background: ${bgGradient}; color: white; box-shadow: 0 20px 25px -5px ${shadowColor}, 0 10px 10px -5px ${shadowColor.replace('0.3', '0.2')}; z-index: 9999; transition: all 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55); font-weight: 600; font-size: 0.9375rem; display: flex; align-items: center; gap: 0.625rem; min-width: 280px; justify-content: center; backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.2);`;
    
    document.body.appendChild(flashDiv);
    
    // Slide in animation
    setTimeout(() => {
      flashDiv.style.transform = 'translateX(-50%) translateY(0)';
    }, 10);
    
    // Auto dismiss after 2 seconds
    setTimeout(() => {
      flashDiv.style.opacity = '0';
      flashDiv.style.transform = 'translateX(-50%) translateY(-100px)';
      flashDiv.style.scale = '0.9';
      setTimeout(() => flashDiv.remove(), 400);
    }, 2000);
  }

  // Price Range Slider Handler
  document.addEventListener('DOMContentLoaded', function() {
    const minPriceSlider = document.getElementById('minPriceSlider');
    const maxPriceSlider = document.getElementById('maxPriceSlider');
    const minPriceDisplay = document.getElementById('minPriceDisplay');
    const maxPriceDisplay = document.getElementById('maxPriceDisplay');
    const minPriceInput = document.getElementById('minPrice');
    const maxPriceInput = document.getElementById('maxPrice');
    const activeRange = document.getElementById('activeRange');
    
    if (minPriceSlider && maxPriceSlider) {
      const priceMin = parseFloat(minPriceSlider.min);
      const priceMax = parseFloat(minPriceSlider.max);
      
      function updateRangeSlider() {
        const minValue = parseFloat(minPriceSlider.value);
        const maxValue = parseFloat(maxPriceSlider.value);
        
        // Ensure min doesn't exceed max and vice versa
        if (minValue > maxValue) {
          if (minPriceSlider === document.activeElement) {
            maxPriceSlider.value = minValue;
          } else {
            minPriceSlider.value = maxValue;
          }
        }
        
        const finalMin = parseFloat(minPriceSlider.value);
        const finalMax = parseFloat(maxPriceSlider.value);
        
        // Update displays
        minPriceDisplay.textContent = Math.round(finalMin);
        maxPriceDisplay.textContent = Math.round(finalMax);
        
        // Update hidden inputs
        minPriceInput.value = finalMin;
        maxPriceInput.value = finalMax;
        
        // Update active range visual
        const minPercent = ((finalMin - priceMin) / (priceMax - priceMin)) * 100;
        const maxPercent = ((finalMax - priceMin) / (priceMax - priceMin)) * 100;
        activeRange.style.left = minPercent + '%';
        activeRange.style.width = (maxPercent - minPercent) + '%';
      }
      
      // Style the range sliders
      function styleRangeSlider(slider) {
        slider.style.webkitAppearance = 'none';
        slider.style.appearance = 'none';
        slider.style.height = '8px';
        slider.style.background = 'transparent';
        slider.style.outline = 'none';
        slider.style.pointerEvents = 'auto';
        
        // Thumb styling
        const style = document.createElement('style');
        style.textContent = `
          #minPriceSlider::-webkit-slider-thumb,
          #maxPriceSlider::-webkit-slider-thumb {
            -webkit-appearance: none;
            appearance: none;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            background: #2563eb;
            cursor: pointer;
            border: 3px solid white;
            box-shadow: 0 2px 6px rgba(0,0,0,0.3);
            position: relative;
            z-index: 30;
          }
          #minPriceSlider::-moz-range-thumb,
          #maxPriceSlider::-moz-range-thumb {
            width: 20px;
            height: 20px;
            border-radius: 50%;
            background: #2563eb;
            cursor: pointer;
            border: 3px solid white;
            box-shadow: 0 2px 6px rgba(0,0,0,0.3);
            position: relative;
            z-index: 30;
          }
          #minPriceSlider::-webkit-slider-thumb:hover,
          #maxPriceSlider::-webkit-slider-thumb:hover {
            background: #1d4ed8;
            transform: scale(1.1);
          }
          #minPriceSlider::-moz-range-thumb:hover,
          #maxPriceSlider::-moz-range-thumb:hover {
            background: #1d4ed8;
            transform: scale(1.1);
          }
        `;
        if (!document.getElementById('rangeSliderStyle')) {
          style.id = 'rangeSliderStyle';
          document.head.appendChild(style);
        }
      }
      
      styleRangeSlider(minPriceSlider);
      styleRangeSlider(maxPriceSlider);
      
      // Initialize
      updateRangeSlider();
      
      // Add event listeners
      minPriceSlider.addEventListener('input', updateRangeSlider);
      maxPriceSlider.addEventListener('input', updateRangeSlider);
    }
    
    // Handle Add to Cart button clicks
    const addToCartButtons = document.querySelectorAll('.add-to-cart-btn');
    
    addToCartButtons.forEach(button => {
      button.addEventListener('click', async function(e) {
        e.preventDefault();
        const productId = this.getAttribute('data-product-id');
        const btnText = this.querySelector('.btn-text');
        const originalText = btnText.textContent;
        
        // Disable button and show loading state
        this.disabled = true;
        btnText.textContent = 'Adding...';
        
        try {
          const response = await fetch(`/addtocart/${productId}`, {
            method: 'GET',
            headers: {
              'Accept': 'application/json',
            }
          });
          
          const data = await response.json();
          
          if (data.success) {
            showFlashMessage(data.message, 'success');
            btnText.textContent = 'Added!';
            setTimeout(() => {
              btnText.textContent = originalText;
              this.disabled = false;
            }, 1000);
          } else {
            showFlashMessage(data.message || 'Failed to add to cart', 'error');
            btnText.textContent = originalText;
            this.disabled = false;
          }
        } catch (error) {
          console.error('Error:', error);
          showFlashMessage('Failed to add to cart', 'error');
          btnText.textContent = originalText;
          this.disabled = false;
        }
      });
    });
  });
</script>

<%- include('./partials/footer') %>