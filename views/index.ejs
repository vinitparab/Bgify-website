<%- include('./partials/header') %>

<!-- Flash Messages -->
<% if (error && error.length > 0) { %>
  <div id="flashMessageError"
       class="fixed top-24 left-1/2 -translate-x-1/2 px-6 py-3 rounded-lg bg-red-500 text-white shadow-xl z-[9999] border border-red-700 font-medium text-sm transition-all duration-500">
    <%= error[0] %>
  </div>
  <script>
    setTimeout(() => {
      const flash = document.getElementById('flashMessageError');
      if (flash) {
        flash.style.opacity = '0';
        flash.style.transform = 'translate(-50%, -20px)';
        setTimeout(() => flash.remove(), 500);
      }
    }, 4000);
  </script>
<% } %>

<% if (success && success.length > 0) { %>
  <div id="flashMessage"
       class="fixed top-24 left-1/2 -translate-x-1/2 px-6 py-3 rounded-lg bg-green-500 text-white shadow-xl z-[9999] border border-green-700 font-medium text-sm transition-all duration-500">
    <%= success[0] %>
  </div>
  <script>
    setTimeout(() => {
      const flash = document.getElementById('flashMessage');
      if (flash) {
        flash.style.opacity = '0';
        flash.style.transform = 'translate(-50%, -20px)';
        setTimeout(() => flash.remove(), 500);
      }
    }, 4000);
  </script>
<% } %>

<!-- Auth Container -->
<div class="w-full min-h-screen bg-gradient-to-r from-blue-100 to-purple-100 flex items-center justify-center py-16 px-10">
  <div class="bg-white/70 backdrop-blur-md shadow-2xl rounded-2xl w-full max-w-5xl flex overflow-hidden border border-gray-200">

    <!-- Register Section -->
    <div class="w-1/2 p-10 bg-white/60 backdrop-blur-lg">
      <h2 class="text-3xl font-bold mb-2 text-gray-800">Join <span class="text-blue-600">Scatch</span></h2>
      <p class="text-sm text-gray-600 mb-6">Create your account to start shopping</p>

      <form action="/users/register" method="POST" autocomplete="off" class="space-y-4">
        <div>
          <label class="block text-gray-700 mb-1">Full Name</label>
          <input name="fullname" type="text" placeholder="John Doe"
                 class="w-full px-4 py-2 border border-gray-300 rounded-md bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-400">
        </div>
        <div>
          <label class="block text-gray-700 mb-1">Email</label>
          <input name="email" type="email" placeholder="you@example.com"
                 class="w-full px-4 py-2 border border-gray-300 rounded-md bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-400">
        </div>
        <div>
          <label class="block text-gray-700 mb-1">Password</label>
          <input name="password" type="password" placeholder="••••••••"
                 class="w-full px-4 py-2 border border-gray-300 rounded-md bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-400">
        </div>
        <button type="submit"
                class="w-full py-3 mt-3 bg-blue-600 hover:bg-blue-700 text-white rounded-md font-semibold transition-all">
          <i class="ri-user-add-line mr-2"></i> Create My Account
        </button>
      </form>
    </div>

    <!-- Login Section -->
    <div class="w-1/2 p-10 bg-gradient-to-tr from-blue-600 to-purple-600 text-white flex flex-col justify-center">
      <h2 class="text-3xl font-bold mb-2">Welcome Back</h2>
      <p class="text-sm text-gray-200 mb-6">Login to continue your shopping experience</p>

      <form action="/users/login" method="POST" autocomplete="off" class="space-y-4">
        <div>
          <label class="block text-white/80 mb-1">Email</label>
          <input name="email" type="email" placeholder="you@example.com"
                 class="w-full px-4 py-2 border border-white/30 rounded-md bg-white/20 text-white placeholder-white/70 focus:outline-none focus:ring-2 focus:ring-white">
        </div>
        <div>
          <label class="block text-white/80 mb-1">Password</label>
          <input name="password" type="password" placeholder="••••••••"
                 class="w-full px-4 py-2 border border-white/30 rounded-md bg-white/20 text-white placeholder-white/70 focus:outline-none focus:ring-2 focus:ring-white">
        </div>
        <button type="submit"
                class="w-full py-3 mt-3 bg-white text-blue-600 hover:bg-gray-100 font-semibold rounded-md transition-all">
          <i class="ri-login-box-line mr-2"></i> Login
        </button>
      </form>
    </div>
  </div>
</div>

<%- include('./partials/footer') %>
